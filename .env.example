# ── Bot ───────────────────────────────────────────────────
BOT_TOKEN=

# ── Admin (vergul bilan ajrating, masalan: 123456,789012) ─
ADMIN_IDS=

# ── Kanal (foydalanuvchi obuna bo'lishi shart bo'lgan) ────
CHANNEL_USERNAME=@laminox

# ── Xavfsizlik ────────────────────────────────────────────
COOLDOWN_SECONDS=15

# ── Watermark ─────────────────────────────────────────────
# true  → barcha videolarga pastki o'ng burchakda matn qo'shiladi
# false → watermark o'chirilgan
WATERMARK_ENABLED=true
WATERMARK_TEXT=@laminox

# ── FFmpeg siqish (ixtiyoriy) ─────────────────────────────
# VIDEO_CRF: 18=yuqori sifat/katta hajm, 28=kichik hajm (standart)
VIDEO_CRF=28
VIDEO_AUDIO_BITRATE=128k
AUDIO_BITRATE=128k

# ── YouTube Cookie (anti-bot) ─────────────────────────────
# "Sign in to confirm you're not a bot" xatoligidan himoya
#
# FOYDALANISH:
#   1. Brauzeringizda YouTube'ga kiring
#   2. "Get cookies.txt LOCALLY" (Chrome extension) bilan cookies.txt eksport qiling
#   3. cookies.txt ni loyiha ildiziga joylang (bot.py bilan bir papkada)
#   4. YOUTUBE_COOKIES_ENABLED=true qiling
#
# MUHIM: cookies.txt ni GitHub'ga push QILMANG (.gitignore ga qo'shilgan)
# Railway uchun: Railway Volumes yoki startup script ishlatiladi
YOUTUBE_COOKIES_ENABLED=true
COOKIES_PATH=cookies.txt

# ── Ma'lumotlar bazasi ────────────────────────────────────
DB_PATH=database.db
