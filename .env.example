# ════════════════════════════════════════════════════
# LAMINOX Downloader Bot — .env sozlamalari
# ════════════════════════════════════════════════════
# Bu faylni nusxa ko'ching: cp .env.example .env
# Keyin .env faylini o'zingizning qiymatlaringiz bilan to'ldiring.
# .env faylini hech qachon GitHub'ga yuklamang!

# ── Bot (majburiy) ───────────────────────────────────────
# @BotFather dan oling
BOT_TOKEN=

# ── Admin (majburiy) ─────────────────────────────────────
# Vergul bilan ajrating: 123456789,987654321
# ID'ingizni @userinfobot dan bilib oling
ADMIN_IDS=

# ── Kanal ────────────────────────────────────────────────
# Foydalanuvchi obuna bo'lishi shart bo'lgan kanal
# @username yoki -100xxxxxxx (supergroup/channel ID)
CHANNEL_USERNAME=@laminox

# ── Xavfsizlik ───────────────────────────────────────────
# Foydalanuvchilar orasidagi minimal vaqt oraliq (soniyada)
COOLDOWN_SECONDS=15

# ── Watermark ────────────────────────────────────────────
# true  → barcha videolarga pastki o'ng burchakda matn qo'shiladi
# false → watermark o'chirilgan
WATERMARK_ENABLED=true
WATERMARK_TEXT=@laminox

# ── FFmpeg siqish ─────────────────────────────────────────
# VIDEO_CRF: 18=yuqori sifat (katta hajm) → 28=kichik hajm (standart)
# Telegram limiti: 50 MB. Bot 720p→480p→360p tushib siqadi.
VIDEO_CRF=28
VIDEO_AUDIO_BITRATE=128k
AUDIO_BITRATE=128k

# ── YouTube Cookie (anti-bot) ─────────────────────────────
# "Sign in to confirm you're not a bot" xatoligidan himoya.
#
# FOYDALANISH:
#   1. Chrome'da YouTube'ga kiring
#   2. "Get cookies.txt LOCALLY" extension bilan cookies.txt eksport qiling
#   3. cookies.txt ni loyiha ildiziga joylashtiring
#   4. Quyidagi sozlamalarni faollashtiring
#
# MUHIM: cookies.txt ni GitHub'ga push QILMANG (.gitignore da bloklanган)
# Railway uchun: COOKIES_PATH=/app/cookies.txt deb qo'ying
YOUTUBE_COOKIES_ENABLED=true
COOKIES_PATH=cookies.txt

# ── Proxy (ixtiyoriy) ────────────────────────────────────
# Bo'sh qoldirilsa proxy ishlatilmaydi.
# Proxy ishlamasa bot avtomatik proxysiz qayta urinadi.
#
# Formatlar:
#   http://host:port
#   http://username:password@host:port
#   socks5://username:password@host:port
#
# Misol:
#   PROXY_URL=http://user:pass@123.456.789.0:8080
#   PROXY_URL=socks5://user:pass@proxy.example.com:1080
PROXY_URL=

# ── Ma'lumotlar bazasi ────────────────────────────────────
DB_PATH=database.db
