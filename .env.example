# ── Bot ───────────────────────────────────────────────────
BOT_TOKEN=

# ── Admin (vergul bilan ajrating, masalan: 123456,789012) ─
ADMIN_IDS=

# ── Kanal (foydalanuvchi obuna bo'lishi shart bo'lgan) ────
CHANNEL_USERNAME=@laminox

# ── Xavfsizlik ────────────────────────────────────────────
COOLDOWN_SECONDS=15

# ── Watermark ─────────────────────────────────────────────
# true  → barcha videolarga pastki o'ng burchakda matn qo'shiladi
# false → watermark o'chirilgan
WATERMARK_ENABLED=true
WATERMARK_TEXT=@laminox

# ── FFmpeg siqish (ixtiyoriy) ─────────────────────────────
# VIDEO_CRF: 18=yuqori sifat/katta hajm, 28=kichik hajm (standart)
VIDEO_CRF=28
VIDEO_AUDIO_BITRATE=128k
AUDIO_BITRATE=128k

# ── Ma'lumotlar bazasi ────────────────────────────────────
DB_PATH=database.db
